# ====== LLM ======
# Провайдер: openai (по умолчанию). Сверка с заданием: "LLM на выбор".
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
# ОБЯЗАТЕЛЬНО: подставьте свой ключ. Не коммитьте .env!
LLM_API_KEY=
# Опц.: для OpenAI-совместимых провайдеров (например, локальная Ollama или vLLM)
# LLM_BASE_URL=http://localhost:11434/v1
LLM_TEMPERATURE=0

# ====== Источник данных ======
# По умолчанию指向 ./app/fixtures/obligations.json
# OBLIGATIONS_PATH=/app/app/fixtures/obligations.json

# ====== frankfurter.app ======
FRANKFURTER_BASE_URL=https://api.frankfurter.dev
# Кеш курса в секундах. ECB обновляет курсы раз в рабочий день,
# поэтому 86400 (24ч) не приводит к потере актуальности.
# При желании поставьте меньше (например 3600).
CURRENCY_CACHE_TTL_SECONDS=86400

# ====== Бизнес-настройки ======
DEFAULT_TARGET_CURRENCY=RUB
LOCAL_TIMEZONE=Europe/Minsk
