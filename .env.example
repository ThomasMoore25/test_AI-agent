# ====== LLM: GigaChat (Сбер) ======
# Сверка с заданием: "LLM на твой выбор".
# Выбор обоснован: это стажировка в Сбере → нативная LLM Сбера GigaChat.
# Получить ключ: https://developers.sber.ru/ (нужна учетная запись Сбера).

LLM_PROVIDER=gigachat
LLM_MODEL=GigaChat-Mini

# ОБЯЗАТЕЛЬНО: подставьте свой ключ GigaChat. Не коммитьте .env!
GIGACHAT_API_KEY=

# Scope авторизации:
#   GIGACHAT_API_PERS  — для физических лиц (по умолчанию)
#   GIGACHAT_API_B2B   — для B2B
#   GIGACHAT_API_CORP  — для корпоративных клиентов
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Endpoint API GigaChat (менять не нужно)
GIGACHAT_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1

# GigaChat использует SSL-сертификаты Минцифры РФ. В dev-режиме можно
# отключить проверку (False). В прод-режиме установите сертификат в ОС
# и поставьте True.
GIGACHAT_VERIFY_SSL_CERTS=False

LLM_TEMPERATURE=0

# ====== Источник данных ======
# По умолчанию指向 ./app/fixtures/obligations.json
# OBLIGATIONS_PATH=/app/app/fixtures/obligations.json

# ====== frankfurter.app ======
FRANKFURTER_BASE_URL=https://api.frankfurter.app
# Кеш курса в секундах. ECB обновляет курсы раз в рабочий день,
# поэтому 86400 (24ч) не приводит к потере актуальности.
CURRENCY_CACHE_TTL_SECONDS=86400

# ====== Бизнес-настройки ======
DEFAULT_TARGET_CURRENCY=RUB
LOCAL_TIMEZONE=Europe/Minsk
